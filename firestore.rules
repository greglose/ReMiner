rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isLeadOwner() {
      return resource.data.userId == request.auth.uid;
    }

    match /config/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    match /leads/{leadId} {
      allow read: if isAuthenticated() && isLeadOwner();
      allow create: if false;
      allow update: if isAuthenticated() && isLeadOwner();
      allow delete: if false;
    }

    match /emailSequences/{sequenceId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /outreachLog/{logId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /dnc/{phoneHash} {
      allow read, write: if false;
    }

    match /warmup/{configId} {
      allow read: if isAuthenticated() && isOwner(configId);
      allow write: if false;
    }

    match /alerts/{alertId} {
      allow read, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, delete: if false;
    }

    match /metaAudiences/{audienceId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /tokenRefresh/{serviceId} {
      allow read, write: if false;
    }

    match /webhookEvents/{eventId} {
      allow read, write: if false;
    }

    match /_healthcheck/{docId} {
      allow read, write: if false;
    }
  }
}
